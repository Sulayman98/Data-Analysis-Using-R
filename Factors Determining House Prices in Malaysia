library(readxl)

houses = read.csv(file.choose(), header=T)
View(houses)

## Task 1: Cleaning the dataset and creating new variables
#Step 1 Converting empty data or "-" into NaN
houses[houses == "" | houses == "-"] = NA
View(houses) #Check if it works

#Step 2 Changing the variables into numerics
houses$Bedroom = as.numeric(houses$Bathroom)
houses$Bathroom = as.numeric(houses$Bathroom)
houses$Parking.Lot =  as.numeric(houses$Parking.Lot)
houses$Total.Units = as.numeric(houses$Total.Units)

#Step 3 Changing variables with letters into only numerics
houses$price = as.numeric(gsub("RM|\\s", "", houses$price))
houses$Property.Size <- as.numeric(gsub("sq.ft.|,|\\s", "", houses$Property.Size))

View(houses)

#Step 4 Check for Duplication and remove them
sum(duplicated(houses))
houses <- houses[!duplicated(houses), ]

sum(duplicated(houses)) # To confirm there are no more duplicated entries

# Step 5 Creating new meaningful variables
houses$price_per_sqft = houses$price / houses$Property.Size #Normalises the price of houses by size
houses$facilities_count = ifelse( #Counts the number of facilities each entry has
  is.na(houses$Facilities),
  0,
  sapply(strsplit(houses$Facilities, ","), length)
)
View(houses)

# Step 6 Creating a separate new cleaned dataset with only selected variables for analysis
houses_clean = houses[ , !(names(houses) %in% c("description", "Nearby.School", "Ad.List", "Category", "Building.Name", 
                                                "Firm.Type", "Firm.Number", "REN.Number", "Bus.Stop"))]
View(houses_clean)

## Task 2 Data Analysis
# Step 1 Summary Statistics
summary_df = data.frame(
  rbind(
    summary(houses_clean$price),
    summary(houses_clean$Bedroom),
    summary(houses_clean$Bathroom),
    summary(houses_clean$Total.Units),
    summary(houses_clean$facilities_count),
    summary(houses_clean$price_per_sqft)
  )
)
summary_df

rownames(summary_df) = c("price", "bedroom", "bathroom",
                         "total units", "facilities count", "price per sq ft")
summary_df

# Step 2 Boxplots of selected variables
boxplot(houses_clean$price, main= "House Prices", ylab="RM")
boxplot(houses_clean$price_per_sqft, main = "Price per sqft", ylab="RM/sqft")

#Further data cleaning given the presense of outliers
houses_clean[houses_clean$price_per_sqft > 5000, c("price", "Property.Size", "price_per_sqft")] #2 outliers, most likely due to data entry errors

#Creating a new dataset where maximum per sq ft price is less than 5000 per sq ft
houses_clean2 = houses_clean[houses_clean$price_per_sqft <= 5000, ]
houses_clean2 = houses_clean2[houses_clean2$Property.Size <= 10000, ]


summary_df2 = data.frame(
  rbind(
    summary(houses_clean2$price),
    summary(houses_clean2$Bedroom),
    summary(houses_clean2$Bathroom),
    summary(houses_clean2$Total.Units),
    summary(houses_clean2$facilities_count),
    summary(houses_clean2$price_per_sqft),
    summary(houses_clean2$Property.Size),
    summary(houses_clean2$Parking.Lot)
  )
)
summary_df2

rownames(summary_df2) = c("price", "bedroom", "bathroom",
                         "total units", "facilities count", "price per sq ft", "Size", "Parking.Lot")
summary_df2

#Step 3 new boxplot
boxplot(houses_clean2$price_per_sqft, main = "Price per sq ft", ylab= "RM/sqft")

#Step 4 scatterplot of prices against the main variables
plot(houses_clean2$Bedroom, houses_clean2$price_per_sqft,
     main = "Price per Sqft vs Bedroom", xlab = "Bedroom", ylab = "Price per Sqft")

plot(houses_clean2$Bathroom, houses_clean2$price_per_sqft,
     main = "Price per Sqft vs Bathroom", xlab = "Bathroom", ylab = "Price per Sqft")

plot(houses_clean2$Property.Size, houses_clean2$price, 
     main = "Size vs Price", xlab = "Size", ylab = "Price")

plot(houses_clean2$facilities_count, houses_clean2$price_per_sqft,
     main = "Facilities vs Price per sqft", xlab = "Facilities Count", ylab = "Price per sq ft")

plot(houses_clean2$facilities_count, houses_clean2$price,
     main = "Facilities vs Prices", xlab= "Facilities Count", ylab = "Prices")

plot(houses_clean2$Total.Units, houses_clean2$price_per_sqft,
     main = "Total Units in Condominium vs Price per Sqft", xlab = "Total Units", ylab="Price per sq ft")

plot(houses_clean2$Total.Units, houses_clean2$price, 
     main = "Total Units vs Price", xlab= "Total Units", ylab= "Price")

# Step 5 Correlation matrix
variables_for_correl = houses_clean2[, c("price", "Bedroom", "Bathroom",
                                         "Total.Units", "facilities_count",
                                         "Property.Size", "price_per_sqft", "Parking.Lot")]
cor_matrix <- cor(variables_for_correl, use = "complete.obs")
cor_matrix

library(corrplot)
dev.off()
corrplot(cor_matrix, method = "color", type = "upper",
         addCoef.col = "green", tl.col = "blue", tl.srt = 45)

## Task 3: Building a linear regression model
prices.model1 <- lm(price~Property.Size, data=houses_clean2)
summary(prices.model1)
plot(price~Property.Size, data=houses_clean2,main= "House Prices vs Property Size")
abline(prices.model1, col="red")
